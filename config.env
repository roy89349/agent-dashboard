# ── Mission Control — fleet configuration ──────────────────────────────────
# Committed defaults. DO NOT put secrets or machine-specific values here.
# Per-install overrides go in config.local.env (gitignored) — run ./setup.sh to generate it.
# Any value can also be overridden per run, e.g.  MAX_WORKERS=5 ./supervisor.sh

# ── project (what the agents build) ──
: "${REPO:=}"                                  # GitHub owner/repo, e.g. you/your-repo  (REQUIRED — set via setup.sh)
: "${REPO_DIR:=}"                              # local clone of REPO (source for git worktrees) (REQUIRED)
# Multi-repo (optional): $CONTROL_DIR/repos.json can register EXTRA repos next to the primary one
# above. Absent/empty file = single-repo behaviour, byte-identical to today (the simple default path).
: "${REPOS_FILE:=}"                            # resolved to $CONTROL_DIR/repos.json by lib.sh when empty
: "${PROJECT_NAME:=the project}"               # used in agent prompts, e.g. "Acme web app"
: "${PROJECT_DESC:=}"                          # short stack/context for agents, e.g. "Next.js + TypeScript + Postgres"
: "${LABEL_READY:=agent-ready}"                # issues with this label get picked up
: "${GREEN_CMD:=npm run build}"                # the "green gate": a PR is only opened if this succeeds
: "${MAX_TURNS:=30}"                           # hard stop against drift per task (token guard)
: "${ORCH_MAX_TURNS:=60}"                      # higher turn budget when depth=orchestrate (lead coordinates sub-agents)

# ── knowledge base (optional Obsidian / markdown vault) ──
: "${VAULT_DIR:=}"                             # absolute path to a notes vault agents may read; empty = none

# ── parallelism + cost/safety brakes ──
: "${MAX_WORKERS:=3}"                           # how many agents build at once
: "${MAX_PR_PER_DAY:=12}"                       # daily cap: stop claiming above this many PRs/day
: "${FAIL_BREAK:=3}"                            # circuit breaker: pause after N failures in a row

# ── agent sandbox (rootless Podman isolation for the build step) ──
# The build agent runs untrusted task text with --dangerously-skip-permissions, so it MUST be
# isolated from host secrets (gh token, ~/.claude, config.local.env, .env). See docs/sandbox-foundation.md.
: "${FLEET_SANDBOX:=on}"                        # on = build in the Podman sandbox (requires podman); off = build on the HOST (NO isolation — local dev only)
: "${SANDBOX_IMAGE:=localhost/fleet-sandbox:latest}"  # built via deploy/sandbox/build-image.sh (uses deploy/sandbox/Containerfile)
: "${SANDBOX_NET:=pasta}"                       # container network (rootless default = pasta)
: "${CLAUDE_SANDBOX_TOKEN:=}"                   # standalone Claude token for the container; EMPTY = derive a short-lived token from ~/.claude (the refresh-capable creds stay on the host). Put a real value in config.local.env, never here.

# ── smart model routing ──
: "${ROUTER:=auto}"                            # auto = classifier decides; or force 'sonnet'/'opus'
: "${ROUTER_MODEL:=haiku}"                     # cheap model that estimates task complexity
: "${MODEL:=sonnet}"                           # fallback default
: "${EFFORT:=medium}"                          # reasoning effort: low|medium|high|xhigh|max (xhigh/max mainly Opus)
: "${DEPTH:=solo}"                             # solo = one agent per task; orchestrate = the agent fans out into sub-agents (deeper, more tokens)
: "${DEFAULT_ROLE:=}"                          # agents-registry fallback role when no per-task/label match (empty = none → current single-worker behaviour)

# ── reviewer agent ──
: "${REVIEW:=on}"                              # on/off: an agent that comments on every PR
: "${REVIEW_MODEL:=sonnet}"

# ── notification (empty = off) ──
# Set WHATSAPP_TO + NOTIFY_CMD after e.g. 'openclaw channels login --channel whatsapp'.
# The command may use $MSG and $WHATSAPP_TO:
: "${WHATSAPP_TO:=}"
: "${NOTIFY_CMD:=}"                             # e.g. openclaw message send --channel whatsapp --target "$WHATSAPP_TO" --message "$MSG"

# ── telemetry (optional; feeds an external dashboard mirror) ──
: "${STATE_DIR:=$FLEET_DIR/state}"
: "${SUPABASE_MC_URL:=}"                        # separate telemetry project URL (NEVER your production DB)
: "${SUPABASE_MC_WRITE_KEY:=}"                  # write key of the TELEMETRY project

# ── control plane (UI ⇄ fleet via files in $CONTROL_DIR) ──
: "${CONTROL_DIR:=$FLEET_DIR/control}"
# Hard server-side ceilings: the UI can NEVER exceed these (cost-/fork-bomb guard).
: "${HARD_MAX_WORKERS:=8}"
: "${HARD_MAX_PR_PER_DAY:=50}"
: "${HARD_MAX_FAIL_BREAK:=20}"
: "${MIN_FAIL_BREAK:=1}"                        # breaker can never be set to 0 (i.e. never disabled)
: "${MAX_ATTEMPTS_PER_DAY:=40}"                # daily cap on ALL build attempts (failed too = tokens)
: "${ALLOW_GLOBAL_OPUS:=0}"                     # 1 = UI may force opus; otherwise ignored
: "${HEARTBEAT_SEC:=10}"                        # worker heartbeat refresh interval
: "${PHASE_BUDGET_BUILDING_SEC:=1800}"         # soft per-phase budget (only a 'stale' hint, never auto-kill)
: "${PHASE_BUDGET_GATING_SEC:=600}"
: "${PHASE_BUDGET_OTHER_SEC:=300}"
: "${LOG_CHUNK_MAX:=65536}"                     # max bytes per log-tail response (read-DoS guard)

# ── visual PR approval (screenshot of the built app, taken INSIDE the sandbox) ──
# Sellability rule: no external services, no keys, no meters — Playwright/Chromium ship in the
# sandbox image; the feature degrades gracefully (a build NEVER fails because a screenshot failed).
: "${FLEET_SCREENSHOT:=off}"                    # on = capture screenshots after the green gate (requires the playwright-enabled sandbox image)
: "${SCREENSHOT_PATHS:=/}"                      # comma-separated URL paths to capture (first one goes to the phone)
: "${SCREENSHOT_START_CMD:=npm run start}"      # command that serves the BUILT app inside the sandbox
: "${SCREENSHOT_PORT:=3000}"                    # port that command listens on
: "${SCREENSHOT_WAIT_SEC:=25}"                  # max seconds to wait for the app to come up

# ── night shift (use idle night hours for queued chores; off by default) ──
: "${NIGHT_SHIFT:=off}"                         # on = during the night window ALSO claim LABEL_NIGHT issues
: "${LABEL_NIGHT:=night-ready}"                 # label for night-queue chores (docs, tests, dep bumps, refactors)
: "${NIGHT_START_HOUR:=23}"                     # night window start, local server time (inclusive)
: "${NIGHT_END_HOUR:=7}"                        # night window end (exclusive)
: "${NIGHT_MAX_PR:=5}"                          # cap on night-claimed PRs per calendar night

# ── dashboard bridge (worker/supervisor → the Mission Control app on the same host) ──
: "${MC_URL:=http://127.0.0.1:3000}"            # where the dashboard listens
: "${MC_ENV_FILE:=$FLEET_DIR/mission-control/.env.local}"  # source of the internal MC_WATCHDOG_TOKEN

# ── 24/7 loop ──
: "${INTERVAL:=60}"                            # seconds to wait when the backlog is empty

# ── git commit identity (email must map to a GitHub account for CI/preview to attribute) ──
: "${GIT_NAME:=mission-control}"
: "${GIT_EMAIL:=}"                             # empty = use the repo's own git user.email

export REPO REPO_DIR PROJECT_NAME PROJECT_DESC LABEL_READY GREEN_CMD MAX_TURNS ORCH_MAX_TURNS VAULT_DIR \
       MAX_WORKERS MAX_PR_PER_DAY FAIL_BREAK FLEET_SANDBOX SANDBOX_IMAGE SANDBOX_NET CLAUDE_SANDBOX_TOKEN \
       ROUTER ROUTER_MODEL MODEL EFFORT DEPTH DEFAULT_ROLE REVIEW REVIEW_MODEL \
       NOTIFY_CMD WHATSAPP_TO STATE_DIR SUPABASE_MC_URL SUPABASE_MC_WRITE_KEY INTERVAL GIT_NAME GIT_EMAIL \
       CONTROL_DIR HARD_MAX_WORKERS HARD_MAX_PR_PER_DAY HARD_MAX_FAIL_BREAK MIN_FAIL_BREAK \
       MAX_ATTEMPTS_PER_DAY ALLOW_GLOBAL_OPUS HEARTBEAT_SEC \
       PHASE_BUDGET_BUILDING_SEC PHASE_BUDGET_GATING_SEC PHASE_BUDGET_OTHER_SEC LOG_CHUNK_MAX \
       FLEET_SCREENSHOT SCREENSHOT_PATHS SCREENSHOT_START_CMD SCREENSHOT_PORT SCREENSHOT_WAIT_SEC \
       NIGHT_SHIFT LABEL_NIGHT NIGHT_START_HOUR NIGHT_END_HOUR NIGHT_MAX_PR MC_URL MC_ENV_FILE REPOS_FILE
