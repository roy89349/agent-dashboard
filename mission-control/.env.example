# ── Mission Control dashboard env ──────────────────────────────────
# Copy to .env.local (gitignored) or let ./setup.sh generate it. NEVER commit real values.

# Single-user auth (signed session with iat+TTL, no static cookie):
MC_DASHBOARD_PASSWORD=change-me
MC_SESSION_SECRET=<run: openssl rand -hex 32>

# ── control plane (only when CO-LOCATED with the fleet: local or on your server) ──
# Path to the fleet root (this repo). Empty = the parent of mission-control/.
# When deployed away from the fleet (e.g. Vercel), leave unset → live view/control off, board still works.
FLEET_DIR=/absolute/path/to/this/repo
# Local clone of the project repo (lets task-discuss chats read the actual code):
REPO_DIR=/absolute/path/to/your/project/clone

# ── the project the agents build ──
GITHUB_REPO=<owner/repo>
# Fine-grained PAT on ONLY that repo: Contents/Issues/PR write. NO admin, NO workflow, NO other repos.
GITHUB_TOKEN=<fine-grained-PAT>
PROJECT_NAME=<your project name>
PROJECT_DESC=<optional stack/context, e.g. Next.js + Postgres>

# ── optional knowledge base ──
VAULT_DIR=<absolute path to a notes vault, or leave empty>

# ── server-side ceilings (the UI can never exceed these; mirror of config.env) ──
ALLOW_GLOBAL_OPUS=0
HARD_MAX_WORKERS=8
HARD_MAX_PR_PER_DAY=50
MIN_FAIL_BREAK=1
LOG_CHUNK_MAX=65536

# ── voice notes → tasks (Telegram) ─────────────────────────────────
# Speak an idea to the bot; it's transcribed LOCALLY (whisper.cpp) and fed into the same
# "make this a task?" manager-confirm flow a text message uses. NO external STT API, NO keys,
# NO metered costs — the audio + transcript NEVER leave the server. OFF by default.
# Turn on with VOICE_NOTES=on AND set both paths below. Install both with deploy/install-whisper.sh.
VOICE_NOTES=off
# Path to a whisper.cpp binary (main / whisper-cli), printed by deploy/install-whisper.sh:
WHISPER_BIN=/opt/whisper.cpp/build/bin/whisper-cli
# Path to a ggml model. ggml-base/ggml-small = fast; ggml-medium = better Dutch (more RAM/CPU):
WHISPER_MODEL=/opt/whisper.cpp/models/ggml-base.bin
# ffmpeg for OGG/Opus → 16 kHz mono WAV (whisper.cpp needs WAV). Defaults to "ffmpeg" on PATH:
FFMPEG_BIN=ffmpeg
# Optional: force a transcription language (ISO code, e.g. nl) instead of auto-detect:
# WHISPER_LANG=nl

# ── optional telemetry mirror (separate Supabase project; NEVER your production DB) ──
# SUPABASE_MC_URL=https://<telemetry-project>.supabase.co
# SUPABASE_MC_ANON_KEY=<anon key of the telemetry project>
