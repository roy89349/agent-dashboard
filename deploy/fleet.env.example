# dev-fleet env on the VPS — copy to $FLEET_DIR/fleet.env (chmod 600).
# Only what the fleet needs; NEVER your personal full-scope token or the production service-role key.

REPO=<owner/repo>
REPO_DIR=/home/fleet/<repo>
MAX_WORKERS=1                 # start conservatively
MAX_TURNS=30
MAX_PR_PER_DAY=12
FAIL_BREAK=3
ROUTER=auto
REVIEW=on
GIT_NAME=dev-fleet
GIT_EMAIL=you@example.com     # must map to a GitHub account (for preview deploys)

# WhatsApp ping (after 'openclaw channels login --channel whatsapp'):
WHATSAPP_TO=+10000000000
NOTIFY_CMD=openclaw message send --channel whatsapp --target "$WHATSAPP_TO" --message "$MSG"

# Telemetry → SEPARATE mission-control Supabase project (NEVER production):
SUPABASE_MC_URL=https://<mission-control-ref>.supabase.co
SUPABASE_MC_WRITE_KEY=<restricted write key / fleet_writer of the TELEMETRY project>

# GitHub auth goes through 'gh auth login' with the FINE-GRAINED PAT (not stored here in plaintext).
