[Unit]
Description=Mission Control morning digest (daily standup summary to Telegram)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=fleet
ExecStart=/home/fleet/agent-dashboard/deploy/morning-digest.sh
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# ── hardening (mirrors mission-control-dashboard.service) ──
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectControlGroups=true
ProtectKernelTunables=true
ProtectKernelModules=true
RestrictSUIDSGID=true
